{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "bash .claude/hooks/session-start.sh",
          "timeout": 10000,
          "statusMessage": "Checking workspace health..."
        }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash .claude/hooks/safe-commit.sh",
          "timeout": 5000,
          "statusMessage": "Checking worktree guard..."
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "bash .claude/hooks/check-edited-file.sh",
          "timeout": 15000,
          "statusMessage": "Checking import boundaries..."
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash .claude/hooks/commit-review.sh",
          "timeout": 5000,
          "statusMessage": "Checking for post-commit review..."
        }]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(*)",
      "Agent(*)"
    ]
  }
}
