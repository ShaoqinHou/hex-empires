{
  "name": "@hex/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "tsc -b && vite build",
    "build:deploy": "tsc -b && vite build --base=/hex-empires/",
